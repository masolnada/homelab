  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-zigbee"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "black"
          },
          "custom": {
            "lineWidth": 2,
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "fillOpacity": 0,
            "gradientMode": "none",
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "off"
