      "id": 1,
      "options": {
        "legend": { "displayMode": "hidden", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-zigbee" },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"esphome_sensor\")\n  |> filter(fn: (r) => r.entity == \"flow_rate\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "title": "Flow rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-zigbee"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "black"
          },
          "custom": {
            "lineWidth": 2,
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "spanNulls": false,
            "fillOpacity": 80,
            "gradientMode": "none",
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "off"
            }
