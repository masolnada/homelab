        "legend": { "displayMode": "hidden", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-zigbee" },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"esphome_sensor\")\n  |> filter(fn: (r) => r.entity == \"total_water\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)",
          "refId": "A"
        }
      ],
      "title": "Water used per period",
      "type": "timeseries"
    },
