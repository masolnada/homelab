TIMEZONE=Europe/Madrid
MQTT_USERNAME=mosquitto
MQTT_PASSWORD=

# Zigbee2MQTT (zb-coord-baixos) — generate once, never change after pairing.
# Values are JSON-parsed by z2m: arrays without spaces, PAN ID in DECIMAL (no hex).
# Key:        python3 -c "import secrets; print(str([secrets.randbelow(256) for _ in range(16)]).replace(' ',''))"
# PAN ID:     decimal 1-65527, unique per coordinator (e.g. 59735)
# Ext PAN ID: 8-byte array like the key, unique per coordinator
Z2M_BAIXOS_NETWORK_KEY=
Z2M_BAIXOS_PAN_ID=
Z2M_BAIXOS_EXT_PAN_ID=

# Zigbee2MQTT (zb-coord-pis) — same rules as above, values unique per coordinator.
Z2M_PIS_NETWORK_KEY=
Z2M_PIS_PAN_ID=
Z2M_PIS_EXT_PAN_ID=

# InfluxDB 2 — these apply ONLY on first boot (empty influxdb_data volume).
# Get them wrong and you must `docker volume rm automation_influxdb_data` to
# redo the setup; editing them afterwards has no effect.
# Token: openssl rand -hex 32
# The bucket name is also hard-coded in the provisioned Grafana dashboards'
# Flux queries — renaming it here means editing automation/grafana/dashboards/.
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=
INFLUXDB_ORG=homelab
INFLUXDB_BUCKET=zigbee
INFLUXDB_TOKEN=

# Grafana — admin credentials apply on first boot only (stored in grafana.db
# afterwards). DOMAIN must match gateway/.env; grafana needs it to build its
# public root URL behind Caddy.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
DOMAIN=
